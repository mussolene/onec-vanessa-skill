# Required local paths
OVS_1C_BIN=
OVS_VANESSA_EPF=
OVS_XUNIT_EPF=

# Connection settings
OVS_IB_CONNECTION=
OVS_DB_USER=
OVS_DB_PASSWORD=

# Optional runtime tools
OVS_VRUNNER=
OVS_OSCRIPT=

# Optional Vanessa screenshot settings.
# Screenshots require either a configured command or VanessaExt-based screenshot support.
OVS_VA_ENABLE_SCREENSHOTS=false
OVS_VA_SCREENSHOT_COMMAND=
OVS_VA_USE_ADDIN_FOR_SCREENSHOTS=false

# Optional project paths
OVS_UI_PATH=examples/ui
OVS_UI_LIBRARIES=examples/ui/libraries
OVS_XUNIT_PATH=examples/xunit
OVS_UI_SMOKE_PATH=examples/ui
OVS_XUNIT_SMOKE_PATH=examples/xunit
